{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Core permissions required by the Databara main window (event listening, window close handling, in-app updates).",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:default",
    "updater:default",
    "process:allow-restart",
    "opener:default",
    "opener:allow-open-url"
  ]
}
