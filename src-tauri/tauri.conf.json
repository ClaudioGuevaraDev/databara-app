{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Databara",
  "version": "1.1.5",
  "identifier": "dev.databara.app",
  "build": {
    "beforeDevCommand": "pnpm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Databara",
        "width": 1440,
        "height": 920,
        "minWidth": 1120,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis", "app", "dmg", "appimage", "deb", "rpm"],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/ClaudioGuevaraDev/databara-app/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJFRTZCOTUwMjk4OTREN0MKUldSOFRZa3BVTG5tTG5wMFgzZUNuZmZMeFFEUkpaK0JpNXlwMjYzUE5YTTY2aWNXSU9mb3Z5OFoK"
    }
  }
}
