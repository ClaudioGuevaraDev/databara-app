{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Databara",
  "version": "0.1.0",
  "identifier": "dev.databara.app",
  "build": {
    "beforeDevCommand": "pnpm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Databara",
        "width": 1440,
        "height": 920,
        "minWidth": 1120,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  }
}
